# ─────────────────────────────────────────────
# GOT-AI Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LangSmith observability (optional) ────────
# Sign up at https://smith.langchain.com to get a free API key.
# Leave LANGCHAIN_TRACING_V2=false to disable tracing entirely.
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=GOT-AI
LANGCHAIN_TRACING_V2=false

# ── Model overrides (optional) ────────────────
# Defaults shown. Change if you want a different Ollama model.
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# ── Debug output (optional) ───────────────────
# Set to true to print [AGENT] routing decisions, retrieved context,
# and raw LLM responses to stdout.
DEBUG=false
